<?php
/**
 * Homepage hero slider: uses 1..3 CMS blocks or placeholders.
 *
 * CMS block identifiers:
 * - topocentras-hero-slide-1
 * - topocentras-hero-slide-2
 * - topocentras-hero-slide-3
 *
 * Each CMS block can contain your full slide markup (image + text + button).
 *
 * @var $block \Magento\Framework\View\Element\Template
 */

/** @var \Magento\Framework\View\Element\Template $block */
$slide1 = $block->getChildHtml('topocentras.hero.slide.1', false);
$slide2 = $block->getChildHtml('topocentras.hero.slide.2', false);
$slide3 = $block->getChildHtml('topocentras.hero.slide.3', false);

$slides = [$slide1, $slide2, $slide3];
$hasAny = false;
foreach ($slides as $s) {
    if (trim((string)$s)) { $hasAny = true; break; }
}

$fallbackImages = [
    'https://picfit.topocentras.lt/xcdn-cgi/image/fit=contain,format=auto,quality=85/media/wysiwyg/Akcijubaneriai2026/CM-3161-AU_-DR_TE-1080x1330.jpg',
    'https://picfit.topocentras.lt/xcdn-cgi/image/fit=contain,format=auto,quality=85/media/wysiwyg/Akcijubaneriai2026/CM-3160-AU_-DR_DU-1080x1330.jpg',
    'https://picfit.topocentras.lt/xcdn-cgi/image/fit=contain,format=auto,quality=85/media/wysiwyg/Akcijubaneriai2026/CM-3163-AU_-DR_PL-1080x1330.jpg',
    'https://picfit.topocentras.lt/xcdn-cgi/image/fit=contain,format=auto,quality=85/media/wysiwyg/Akcijubaneriai2026/CM-3116-AU_-DR_NE-1080x1330.jpg',
];
?>

<section class="topocentras-home-slider" aria-label="<?= $block->escapeHtmlAttr(__('Homepage slider')) ?>">
    <div class="topocentras-home-slider__viewport">
        <?php if ($hasAny): ?>
            <?php foreach ($slides as $i => $html): ?>
                <?php if (!trim((string)$html)) continue; ?>
                <div class="topocentras-home-slider__slide<?= $i === 0 ? ' is-active' : '' ?>" data-slide aria-hidden="<?= $i === 0 ? 'false' : 'true' ?>">
                    <?= /* @noEscape */ $html ?>
                </div>
            <?php endforeach; ?>
        <?php else: ?>
            <?php foreach ($fallbackImages as $i => $src): ?>
                <div class="topocentras-home-slider__slide<?= $i === 0 ? ' is-active' : '' ?>" data-slide aria-hidden="<?= $i === 0 ? 'false' : 'true' ?>">
                    <a class="topocentras-home-slider__img-link" href="<?= $block->escapeUrl($block->getUrl('catalog')) ?>" aria-label="<?= $block->escapeHtmlAttr(__('Promotion %1', $i + 1)) ?>">
                        <img
                            class="topocentras-home-slider__img"
                            src="<?= $block->escapeUrl($src) ?>"
                            alt="<?= $block->escapeHtmlAttr(__('Promotion %1', $i + 1)) ?>"
                            loading="<?= $i === 0 ? 'eager' : 'lazy' ?>"
                        />
                    </a>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>
    </div>

    <button class="topocentras-home-slider__prev" type="button" aria-label="<?= $block->escapeHtmlAttr(__('Previous')) ?>"></button>
    <button class="topocentras-home-slider__next" type="button" aria-label="<?= $block->escapeHtmlAttr(__('Next')) ?>"></button>
    <div class="topocentras-home-slider__dots" aria-hidden="true"></div>
</section>

