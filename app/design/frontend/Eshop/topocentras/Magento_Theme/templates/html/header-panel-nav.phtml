<?php
/**
 * Topocentras-style top bar nav: Catalog (Prekių katalogas) + Akcijos + optional links.
 * Renders in header.panel so the dark blue bar shows these links with separators.
 *
 * @var $block \Magento\Framework\View\Element\Template
 */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$rootCategoryId = (int) $storeManager->getStore()->getRootCategoryId();
$catalogUrl = $block->getUrl('catalog/category/view', ['id' => $rootCategoryId]);
try {
    $categoryRepository = $objectManager->get(\Magento\Catalog\Api\CategoryRepositoryInterface::class);
    $category = $categoryRepository->get($rootCategoryId);
    $catalogUrl = $category->getUrl();
} catch (\Exception $e) {
    // use default
}
// Sale / Akcijos: set sale_url via layout argument to point to your sale/promotions page
$saleUrl = $block->getData('sale_url') ?: $catalogUrl;
?>
<ul class="header links topocentras-panel-nav">
    <li class="level0 nav-catalog first">
        <a href="<?= $block->escapeUrl($catalogUrl) ?>" class="level-top"><?= $block->escapeHtml(__('Prekių katalogas')) ?></a>
    </li>
    <li class="level0 nav-sale">
        <a href="<?= $block->escapeUrl($saleUrl) ?>" class="level-top"><?= $block->escapeHtml(__('Akcijos')) ?></a>
    </li>
</ul>
