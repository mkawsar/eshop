<?php
/**
 * Left sidebar: Topocentras-style catalog menu (header + category list with icons).
 * @var $block \Magento\Framework\View\Element\Template
 */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$categoryRepository = $objectManager->get(\Magento\Catalog\Api\CategoryRepositoryInterface::class);
$rootId = (int) $storeManager->getStore()->getRootCategoryId();
try {
    $rootCategory = $categoryRepository->get($rootId);
} catch (\Exception $e) {
    return;
}
$children = $rootCategory->getChildrenCategories();
?>
<div class="topocentras-catalog-menu block">
    <div class="catalog-menu-header">
        <span class="catalog-menu-header-accent"></span>
        <div class="catalog-menu-title">
            <span class="catalog-menu-hamburger" aria-hidden="true"></span>
            <span><?= $block->escapeHtml(__('Prekių katalogas')) ?></span>
        </div>
        <a href="<?= $block->escapeUrl($block->getUrl('catalog')) ?>" class="catalog-menu-promo" title="<?= $block->escapeHtmlAttr(__('Akcijos ir pasiūlymai')) ?>">
            <span class="catalog-menu-promo-icon" aria-hidden="true">%</span>
            <span><?= $block->escapeHtml(__('Akcijos ir pasiūlymai')) ?></span>
        </a>
    </div>
    <div class="catalog-menu-list">
        <?php if ($children && $children->count()): ?>
            <ol class="items">
                <?php /** @var \Magento\Catalog\Model\Category $child */ ?>
                <?php foreach ($children as $child): ?>
                    <?php if ($child->getIsActive()): ?>
                        <li class="item catalog-menu-item">
                            <a href="<?= $block->escapeUrl($child->getUrl()) ?>">
                                <span class="catalog-menu-icon" aria-hidden="true"></span>
                                <span class="catalog-menu-label"><?= $block->escapeHtml($child->getName()) ?></span>
                            </a>
                        </li>
                    <?php endif; ?>
                <?php endforeach; ?>
            </ol>
        <?php else: ?>
            <ul class="items">
                <li class="item catalog-menu-item">
                    <a href="<?= $block->escapeUrl($block->getUrl('catalog')) ?>">
                        <span class="catalog-menu-icon" aria-hidden="true"></span>
                        <span class="catalog-menu-label"><?= $block->escapeHtml(__('Catalog')) ?></span>
                    </a>
                </li>
            </ul>
        <?php endif; ?>
    </div>
</div>
