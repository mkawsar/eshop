<?php
/**
 * Homepage category carousel above New Products.
 * Renders a horizontal carousel of category links (image + label).
 * Uses Owl Carousel classes; ensure owl.carousel JS is loaded and initialized on .categories-container.
 *
 * Optional layout arguments: category_ids (array), limit (int). If not set, uses first-level children of root.
 *
 * @var $block \Magento\Framework\View\Element\Template
 */

use Magento\Framework\App\ObjectManager;

$objectManager = ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$categoryRepository = $objectManager->get(\Magento\Catalog\Api\CategoryRepositoryInterface::class);
$store = $storeManager->getStore();
$rootId = (int) $store->getRootCategoryId();
/** Image CDN base from reference HTML (picfit) – override via layout argument image_cdn_base if needed */
$imageCdnBase = $block->getData('image_cdn_base') ?: 'https://picfit.topocentras.lt/xcdn-cgi/image/fit=contain,format=auto,quality=85';
/** Default 7 to match target: single row of category icons (like Išmanieji telefonai, Televizoriai, etc.) */
$limit = (int) ($block->getData('limit') ?: 7);

$categories = [];
try {
    $rootCategory = $categoryRepository->get($rootId, $store->getId());
    $categoryIds = $block->getData('category_ids');
    if (!empty($categoryIds) && is_array($categoryIds)) {
        foreach (array_slice($categoryIds, 0, $limit) as $catId) {
            try {
                $cat = $categoryRepository->get((int) $catId, $store->getId());
                if ($cat->getIsActive()) {
                    $categories[] = $cat;
                }
            } catch (\Magento\Framework\Exception\NoSuchEntityException $e) {
                continue;
            }
        }
    } else {
        /** @var \Magento\Catalog\Model\ResourceModel\Category\Collection $collection */
        $collection = $objectManager->create(\Magento\Catalog\Model\ResourceModel\Category\Collection::class);
        $collection->addAttributeToSelect(['name', 'image', 'url_path', 'is_active'])
            ->addAttributeToFilter('is_active', 1)
            ->addIdFilter($rootCategory->getChildren())
            ->setOrder('position', \Magento\Framework\DB\Select::SQL_ASC)
            ->setPageSize($limit);
        $collection->setStoreId($store->getId());
        foreach ($collection as $child) {
            $categories[] = $child;
        }
    }
} catch (\Exception $e) {
    $categories = [];
}

if (empty($categories)) {
    return;
}
?>
<div class="imagesContainer-desk" role="region" aria-label="<?= $block->escapeHtmlAttr(__('Shop by category')) ?>">
    <div class="categories-container owl-carousel owl-theme" id="topocentras-category-carousel">
        <?php foreach ($categories as $category): ?>
            <?php
            $name = $category->getName();
            $url = $category->getUrl();
            $image = $category->getData('image');
            $imageUrl = $image
                ? rtrim($imageCdnBase, '/') . '/media/catalog/category/' . $block->escapeUrl($image)
                : '';
            ?>
            <div class="category-carousel-item">
                <a class="category-link" href="<?= $block->escapeUrl($url) ?>">
                    <span class="category-link-image-wrap">
                        <?php if ($imageUrl): ?>
                            <img src="<?= $block->escapeUrl($imageUrl) ?>" alt="<?= $block->escapeHtmlAttr($name) ?>" loading="lazy">
                        <?php else: ?>
                            <span class="category-link-placeholder" aria-hidden="true"></span>
                        <?php endif; ?>
                    </span>
                    <p class="category-title-t"><?= $block->escapeHtml($name) ?></p>
                </a>
            </div>
        <?php endforeach; ?>
    </div>
</div>
