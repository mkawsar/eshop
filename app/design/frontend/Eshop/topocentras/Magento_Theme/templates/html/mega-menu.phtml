<?php
/**
 * Topocentras-style catalog mega menu panel.
 *
 * Uses Magento categories:
 * - Left column: first-level categories under root
 * - Right: second-level lists for each first-level category
 *
 * @var $block \Magento\Framework\View\Element\Template
 */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$escaper = $objectManager->get(\Magento\Framework\Escaper::class);
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$categoryRepository = $objectManager->get(\Magento\Catalog\Api\CategoryRepositoryInterface::class);

$rootId = (int) $storeManager->getStore()->getRootCategoryId();
try {
    $rootCategory = $categoryRepository->get($rootId);
} catch (\Exception $e) {
    return;
}

$level1 = $rootCategory->getChildrenCategories();
?>

<div class="topocentras-mega-menu" aria-hidden="true">
    <div class="topocentras-mega-inner">
        <ul class="topocentras-mega-tabs" role="tablist">
            <?php $i = 0; ?>
            <?php foreach ($level1 as $cat1): ?>
                <?php if (!$cat1->getIsActive()) continue; ?>
                <?php $i++; ?>
                <li class="topocentras-mega-tab<?= $i === 1 ? ' is-active' : '' ?>" role="presentation">
                    <a
                        href="<?= $escaper->escapeUrl($cat1->getUrl()) ?>"
                        class="topocentras-mega-tab-link"
                        data-mega-tab="<?= (int) $cat1->getId() ?>"
                        role="tab"
                    >
                        <span class="topocentras-mega-tab-icon" aria-hidden="true"></span>
                        <span class="topocentras-mega-tab-label"><?= $escaper->escapeHtml($cat1->getName()) ?></span>
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>

        <div class="topocentras-mega-panels">
            <?php foreach ($level1 as $cat1): ?>
                <?php if (!$cat1->getIsActive()) continue; ?>
                <?php $children2 = $cat1->getChildrenCategories(); ?>
                <div class="topocentras-mega-panel<?= ((int)$cat1->getId() === (int)($level1->getFirstItem() ? $level1->getFirstItem()->getId() : $cat1->getId())) ? ' is-active' : '' ?>"
                     data-mega-panel="<?= (int) $cat1->getId() ?>"
                     role="tabpanel"
                >
                    <div class="topocentras-mega-panel-title">
                        <a href="<?= $escaper->escapeUrl($cat1->getUrl()) ?>"><?= $escaper->escapeHtml($cat1->getName()) ?></a>
                    </div>

                    <?php if ($children2 && $children2->count()): ?>
                        <div class="topocentras-mega-columns">
                            <?php foreach ($children2 as $cat2): ?>
                                <?php if (!$cat2->getIsActive()) continue; ?>
                                <div class="topocentras-mega-column">
                                    <div class="topocentras-mega-column-title">
                                        <a href="<?= $escaper->escapeUrl($cat2->getUrl()) ?>"><?= $escaper->escapeHtml($cat2->getName()) ?></a>
                                    </div>
                                    <?php $children3 = $cat2->getChildrenCategories(); ?>
                                    <?php if ($children3 && $children3->count()): ?>
                                        <ul class="topocentras-mega-links">
                                            <?php foreach ($children3 as $cat3): ?>
                                                <?php if (!$cat3->getIsActive()) continue; ?>
                                                <li>
                                                    <a href="<?= $escaper->escapeUrl($cat3->getUrl()) ?>"><?= $escaper->escapeHtml($cat3->getName()) ?></a>
                                                </li>
                                            <?php endforeach; ?>
                                        </ul>
                                    <?php endif; ?>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    <?php else: ?>
                        <div class="topocentras-mega-empty">
                            <a href="<?= $escaper->escapeUrl($cat1->getUrl()) ?>"><?= $escaper->escapeHtml(__('Browse')) ?></a>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</div>

