<?xml version="1.0"?>
<!--
/**
 * Homepage layout: Top Navigation + Main Layout (Sidebar + Hero + Promo) + Full-width Product Grid.
 * Sidebar height ends at promo row; product grid is full width below.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd" layout="1column">
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <!-- Main layout: sidebar + hero + product cards (promo); sidebar ends here -->
            <container name="main.layout" htmlTag="div" htmlClass="main-layout">
                <block class="Magento\Framework\View\Element\Template"
                       name="sidebar.menu"
                       template="Magento_Theme::sidebar-menu.phtml"/>
                <container name="homepage.content" htmlTag="div" htmlClass="homepage-content">
                    <block class="Magento\Framework\View\Element\Template"
                           name="topocentras.hero.wrapper"
                           template="Magento_Theme::html/hero-slider-with-placeholder.phtml">
                        <block class="Magento\Cms\Block\BlockByIdentifier" name="topocentras.hero.slide.1">
                            <arguments><argument name="identifier" xsi:type="string">topocentras-hero-slide-1</argument></arguments>
                        </block>
                        <block class="Magento\Cms\Block\BlockByIdentifier" name="topocentras.hero.slide.2">
                            <arguments><argument name="identifier" xsi:type="string">topocentras-hero-slide-2</argument></arguments>
                        </block>
                        <block class="Magento\Cms\Block\BlockByIdentifier" name="topocentras.hero.slide.3">
                            <arguments><argument name="identifier" xsi:type="string">topocentras-hero-slide-3</argument></arguments>
                        </block>
                    </block>
                    <block class="Magento\Framework\View\Element\Template"
                           name="topocentras.product.cards"
                           template="Magento_Theme::html/product-cards.phtml"
                           after="topocentras.hero.wrapper"/>
                </container>
            </container>
            <!-- Full-width product grid (below sidebar + hero + promo) -->
            <container name="homepage.products.wrapper" htmlTag="div" htmlClass="homepage-products-fullwidth">
                <block class="Magento\Framework\View\Element\Template"
                       name="topocentras.top.banners.above.new.products"
                       template="Magento_Theme::html/top-banners-above-new-products.phtml"
                       before="topocentras.category.carousel"/>
                <block class="Magento\Framework\View\Element\Template"
                       name="topocentras.category.carousel"
                       template="Magento_Theme::html/category-carousel.phtml"
                       before="homepage.products.list"/>
                <block class="Magento\Catalog\Block\Product\Widget\NewWidget"
                       name="homepage.products.list"
                       template="Magento_Catalog::product/widget/new/content/new_grid.phtml">
                    <arguments>
                        <argument name="display_type" xsi:type="string">all_products</argument>
                        <argument name="products_count" xsi:type="number">12</argument>
                        <argument name="products_per_page" xsi:type="number">12</argument>
                        <argument name="show_pager" xsi:type="boolean">false</argument>
                        <argument name="title" xsi:type="string" translate="true">Products</argument>
                    </arguments>
                </block>
            </container>
        </referenceContainer>
    </body>
</page>
